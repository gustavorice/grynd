# =========================
# App
# =========================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================
# Database — Neon Postgres
# =========================
# Cria conta em neon.tech → New Project → copia o "Connection string" (Pooled)
DATABASE_URL=

# =========================
# Auth — Clerk
# =========================
# clerk.com → Create application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# =========================
# Billing — Stripe
# =========================
# stripe.com (modo Test pra começar)
STRIPE_SECRET_KEY=
# Cria os 3 produtos no Dashboard → Products:
# 1) "Pro Mensal"     R$ 59,90  — recurring monthly  → copia price_xxx aqui
# 2) "Agência Mensal" R$ 199,90 — recurring monthly  → copia price_xxx aqui
# 3) "200 buscas"     R$ 20,00  — one-time           → copia price_xxx aqui
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_ADDON_200=
# Após configurar webhook endpoint apontando pra /api/stripe/webhook:
STRIPE_WEBHOOK_SECRET=

# =========================
# Cache / rate limit — Upstash Redis
# =========================
# upstash.com → Create database (REST) → copia URL + Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =========================
# WhatsApp Cloud API (opcional — só Agência tem acesso)
# =========================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_VERSION=v21.0

# =========================
# Google Places (opcional)
# =========================
GOOGLE_PLACES_API_KEY=

# =========================
# SerpAPI (opcional, recomendado pra prod)
# =========================
# Cria conta gratuita em https://serpapi.com (100 buscas/mês free, $50/mês = 5k)
# Quando setado, busca Google Maps via API HTTP (não precisa de Playwright)
SERPAPI_KEY=
